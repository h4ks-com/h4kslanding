# Django Debug Mode (set to False in production)
DEBUG=True

# Secret key for Django (CHANGE THIS IN PRODUCTION!)
# Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here

# Logto Configuration
# Management API credentials (Machine-to-Machine app)
LOGTO_ENDPOINT=https://auth.h4ks.com
LOGTO_M2M_CLIENT_ID=your-m2m-client-id
LOGTO_M2M_CLIENT_SECRET=your-m2m-client-secret

# User-facing app configuration
LOGTO_APP_ID=your-app-id
LOGTO_APP_SECRET=your-app-secret
LOGTO_REDIRECT_URI=https://h4ks.com/auth/callback

# Stalwart mail server admin API
STALWART_API_URL=https://mail.h4ks.com/api
STALWART_ADMIN_USER=admin
STALWART_ADMIN_SECRET='your-stalwart-fallback-admin-secret'

# Cloudflare Turnstile (signup page bot protection)
TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Port for the standalone clocks app (default: 20001)
CLOCKS_PORT=20001
